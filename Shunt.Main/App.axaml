<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Shunt.Main.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
             
             <TrayIcon.Icons>
                 <TrayIcons>
                     <TrayIcon Icon="avares://Shunt.Main/Assets/icon.ico" 
                               ToolTipText="Shunt">
                         <TrayIcon.Menu>
                             <NativeMenu>
                                 <NativeMenuItem Header="Exit" Click="ExitMenuItem_OnClick" />
                                 <NativeMenuItem Header="Open Settings" Click="OpenSettingsMenuItem_OnClick" />
                             </NativeMenu>
                         </TrayIcon.Menu>
                     </TrayIcon>
                 </TrayIcons>
             </TrayIcon.Icons>
             
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>